    "/conformance": {
      "get": {
        "description": "A list of all conformance classes specified in a standard that\nthe server conforms to.",
        "operationId": "conformance",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Conformance"
                }
              }
            },
            "description": "The URIs of all conformance classes supported by the server.\n\n To support \"generic\" clients that want to access multiple OGC API Features implementations - and not \"just\" a specific API / server, the server declares the conformance classes it implements and conforms to"
          },
          "400": {
            "content": {
              "application/json": {
                "example": {
                  "status": 400,
                  "type": "https://httpwg.org/specs/rfc7231.html#status.400"
                },
