        "type": "object",
        "description": "Hyperlink to enable Hypermedia Access",
        "required": [
          "href",
          "rel"
        ],
        "properties": {
          "href": {
            "type": "string",
            "description": "Supplies the URI to a remote resource (or resource fragment)."
          },
          "rel": {
            "type": "string",
            "description": "The type or semantics of the relation."
          },
          "type": {
            "type": "string",
            "description": "A hint indicating what the media type of the result of dereferencing\nthe link should be."
          },
          "templated": {
            "type": "boolean",
            "description": "This flag set to true if the link is a URL template."
          },
          "varBase": {
            "type": "string",
            "description": "A base path to retrieve semantic information about the variables used in URL template."
          },
          "hreflang": {
            "type": "string",
            "description": "A hint indicating what the language of the result of dereferencing the\nlink should be."
          },
          "title": {
            "type": "string",
            "description": "Used to label the destination of a link such that it can be used as a\nhuman-readable identifier."
          },
          "length": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "MaxOccurs": {
        "oneOf": [
